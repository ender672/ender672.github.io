<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Food for Bot" }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{{ title or 'Food for Bot' }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:type" content="{% if tags and 'post' in tags %}article{% else %}website{% endif %}">
  <meta property="og:url" content="https://ender672.github.io{{ page.url }}">
  <meta property="og:site_name" content="Food for Bot">
  <link rel="canonical" href="https://ender672.github.io{{ page.url }}">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/atom+xml" title="Food for Bot" href="/feed.xml">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1/themes/prism-tomorrow.min.css">
  <style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: rgb(211, 225, 246);
    font-family: sans-serif;
  }

  .content-wrap {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  article.markdown {
    line-height: 1.6em;
    padding-top: 1.5em;

    h1, h2, h3, h4, h5, h6 {
      margin-top: 1.5em;
      margin-bottom: 0.5em;
    }

    h1:first-child,
    h2:first-child,
    h3:first-child {
      margin-top: 0;
    }

    p {
      margin: 1em 0;
    }

    ul, ol {
      padding-left: 1.5em;
    }

    img {
      max-width: 100%;
      height: auto;
    }

    code {
      font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, "DejaVu Sans Mono", monospace;
      background: rgba(0, 0, 0, 0.06);
      padding: 0.15em 0.35em;
      border-radius: 4px;
    }

    pre {
      background: #2d2d2d;
      padding: 1em;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1em 0;
      line-height: 1.6em;

      code {
        background: none;
        padding: 0;
        border-radius: 0;
        font-size: 0.95em;
      }
    }
  }
  </style>
</head>
<body>
  <style>
    header {
      padding: 1.5em 0;
    }

    .post-date {
      display: block;
      color: #555;
      font-size: 0.9em;
      padding-top: 1.5em;
    }

    header a.site-title {
      text-decoration: none;
      color: black;
      font-weight: 800;
      font-size: 1.5em;
    }

    header .content-wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header a.github-link {
      color: #333;
      text-decoration: none;
    }

    header a.github-link:hover {
      color: #000;
    }

    header a.github-link svg {
      width: 24px;
      height: 24px;
      vertical-align: middle;
    }
  </style>
  <header>
    <div class="content-wrap">
      <a class="site-title" href="/">Food for Bot</a>
      <a class="github-link" href="https://github.com/ender672" aria-label="GitHub">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
    </div>
  </header>
  {{ content | safe }}
</body>
</html>
