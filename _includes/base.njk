<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Food for Bot" }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{{ title or 'Food for Bot' }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:type" content="{% if tags and 'post' in tags %}article{% else %}website{% endif %}">
  <meta property="og:url" content="https://ender672.github.io{{ page.url }}">
  <meta property="og:site_name" content="Food for Bot">
  <meta name="author" content="Tim Elliott">
  <link rel="canonical" href="https://ender672.github.io{{ page.url }}">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/atom+xml" title="Food for Bot" href="/feed.xml">
  <link rel="stylesheet" href="/assets/prism-tomorrow.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
  <style>
  :root {
    --bg: #ffffff;
    --text: #111827;
    --text-soft: #374151;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --border-soft: #f3f4f6;
    --link: #4f46e5;
    --link-hover: #3730a3;
    --inline-code-bg: #f3f4f6;
    --inline-code-text: #1f2937;
    --code-bg: #1e1e2e;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    -webkit-text-size-adjust: 100%;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 17px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: "cv11", "ss01", "calt";
    text-rendering: optimizeLegibility;
  }

  .content-wrap {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  a {
    color: var(--link);
    text-decoration: none;
  }

  article.markdown {
    padding-top: 2rem;
    padding-bottom: 4.5rem;
  }

  article.markdown h1 {
    font-size: 2.1rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin-top: 0.5rem;
  }

  article.markdown h2 {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.015em;
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
  }

  article.markdown h3 {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  article.markdown h4,
  article.markdown h5,
  article.markdown h6 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  article.markdown p {
    margin: 1.1rem 0;
    color: var(--text-soft);
  }

  article.markdown ul,
  article.markdown ol {
    padding-left: 1.5rem;
    margin: 1rem 0;
    color: var(--text-soft);
  }

  article.markdown li {
    margin: 0.35rem 0;
  }

  article.markdown a {
    color: var(--link);
    text-decoration: none;
    border-bottom: 1px solid rgba(79, 70, 229, 0.25);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  article.markdown a:hover {
    color: var(--link-hover);
    border-bottom-color: var(--link);
  }

  article.markdown a:has(> img:only-child) {
    border-bottom: none;
  }

  article.markdown blockquote {
    border-left: 3px solid var(--border);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1.25rem 0;
    color: var(--text-muted);
  }

  article.markdown img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
  }

  article.markdown hr {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  article.markdown code {
    font-family: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    background: var(--inline-code-bg);
    color: var(--inline-code-text);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.875em;
    font-feature-settings: "calt" 0;
  }

  article.markdown pre {
    background: var(--code-bg);
    padding: 1rem 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    line-height: 1.6;
    font-size: 0.9rem;
  }

  article.markdown pre code {
    background: none;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .post-meta {
    display: block;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .post-meta time {
    font-variant-numeric: tabular-nums;
  }

  /* Legacy post-date class — kept for backwards compatibility. */
  .post-date {
    display: block;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.85rem;
    margin-bottom: 2.5rem;
    font-variant-numeric: tabular-nums;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border-soft);
  }

  .post-list li:last-child {
    border-bottom: none;
  }

  article.markdown .post-list a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: inherit;
    text-decoration: none;
    border-bottom: none;
  }

  .post-list .post-list-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }

  .post-list a:hover .post-list-title {
    color: var(--link);
  }

  .post-list time {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
  }
  </style>
</head>
<body>
  <style>
    .site-header {
      border-bottom: 1px solid var(--border);
    }

    .site-header .content-wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1.1rem;
      padding-bottom: 1.1rem;
    }

    .site-header a.site-title {
      text-decoration: none;
      color: var(--text);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: -0.01em;
    }

    .site-header a.site-title:hover {
      color: var(--link);
    }

    .site-header a.github-link {
      color: var(--text-muted);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      transition: color 0.15s ease;
    }

    .site-header a.github-link:hover {
      color: var(--text);
    }

    .site-header a.github-link svg {
      width: 20px;
      height: 20px;
      display: block;
    }
  </style>
  <header class="site-header">
    <div class="content-wrap">
      <a class="site-title" href="/">Food for Bot</a>
      <a class="github-link" href="https://github.com/ender672" aria-label="GitHub">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
    </div>
  </header>
  {{ content | safe }}
  <script>
    document.querySelectorAll('article.markdown img').forEach(img => {
      if (img.parentElement.tagName === 'A') return;
      const a = document.createElement('a');
      a.href = img.src;
      img.parentElement.insertBefore(a, img);
      a.appendChild(img);
    });
  </script>
</body>
</html>
