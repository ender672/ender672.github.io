<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Food for Bot" }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{{ title or 'Food for Bot' }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:type" content="{% if tags and 'post' in tags %}article{% else %}website{% endif %}">
  <meta property="og:url" content="https://ender672.github.io{{ page.url }}">
  <meta property="og:site_name" content="Food for Bot">
  <link rel="canonical" href="https://ender672.github.io{{ page.url }}">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/atom+xml" title="Food for Bot" href="/feed.xml">
  <style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: rgb(211, 225, 246);
    font-family: sans-serif;
  }

  .content-wrap {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  article.markdown {
    line-height: 1.6em;
    padding-top: 1.5em;

    h1, h2, h3, h4, h5, h6 {
      margin-top: 1.5em;
      margin-bottom: 0.5em;
    }

    h1:first-child,
    h2:first-child,
    h3:first-child {
      margin-top: 0;
    }

    p {
      margin: 1em 0;
    }

    ul, ol {
      padding-left: 1.5em;
    }

    img {
      max-width: 100%;
      height: auto;
    }

    code {
      font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, "DejaVu Sans Mono", monospace;
      font-size: 0.9em;
      font-weight: 600;
      background: rgba(0, 0, 0, 0.06);
      padding: 0.15em 0.35em;
      border-radius: 4px;
    }

    pre {
      background: rgba(0, 0, 0, 0.06);
      padding: 1em;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1em 0;
      line-height: 1.3em;

      code {
        background: none;
        padding: 0;
        border-radius: 0;
        font-size: 0.85em;
      }
    }
  }
  </style>
</head>
<body>
  <style>
    header {
      padding: 1.5em 0;
    }

    .post-date {
      display: block;
      color: #555;
      font-size: 0.9em;
      padding-top: 1.5em;
    }

    header a.site-title {
      text-decoration: none;
      color: black;
      font-weight: 800;
      font-size: 1.5em;
    }
  </style>
  <header>
    <div class="content-wrap">
      <a class="site-title" href="/">Food for Bot</a>
    </div>
  </header>
  {{ content | safe }}
</body>
</html>
